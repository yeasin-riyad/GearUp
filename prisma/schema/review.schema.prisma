model Review {
  id String @id @default(cuid())

  rating Int

  comment String?

  customerId String
  customer   User   @relation(fields: [customerId], references: [id])

  gearItemId String
  gearItem   GearItem @relation(fields: [gearItemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reviews")
}
