model GearItem {
  id String @id @default(uuid())

  // Basic Information
  name        String
  description String

  brand String?
  image String?

  // Rental Information
  pricePerDay Float
  stock       Int

  availability GearAvailability @default(AVAILABLE)

  // Relations
  providerId String
  provider   User @relation(fields: [providerId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  rentalItems RentalOrderItem[]
  reviews     Review[]

  // Audit Fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([brand])
  @@index([categoryId])
  @@index([providerId])
  @@index([availability])
  @@index([pricePerDay])
  @@index([createdAt])

  @@map("gear_items")
}