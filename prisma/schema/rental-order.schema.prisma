model RentalOrder {
  id String @id @default(cuid())

  customerId String
  customer   User   @relation(fields: [customerId], references: [id])

  items RentalOrderItem[]

  startDate DateTime
  endDate   DateTime

  totalAmount Float

  status RentalStatus

  payment Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
